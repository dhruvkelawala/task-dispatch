# GitHub App webhook verification secret.
# Set this to the same value you paste into the GitHub App webhook Secret field.
GITHUB_WEBHOOK_SECRET=replace-with-github-app-webhook-secret

# Local task-dispatch review endpoint.
TASK_DISPATCH_URL=http://127.0.0.1:18789

# Internal task-dispatch API key used by the bridge when forwarding webhook payloads.
TASK_DISPATCH_API_KEY=replace-with-task-dispatch-api-key

# GitHub App credentials for installation-token issue writing.
GITHUB_APP_ID=replace-with-github-app-id
GITHUB_APP_PRIVATE_KEY_PATH=/absolute/path/to/github-app.private-key.pem
